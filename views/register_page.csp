<!DOCTYPE html>
<html>
<head>
    <title>User Registration</title>
</head>
<body>
    <center>
    <br><br>
    <h2>Register User</h2>

    <form method="POST" action="/register">
        <label>Name:</label><br>
        <input type="text" name="name" autocomplete="name" required><br><br>

        <label>Login:</label><br>
        <input type="text" name="login" autocomplete="username" required><br><br>

        <label>Password:</label><br>
        <input type="password" name="password" autocomplete="new-password" required><br><br>

        <label>Confirm Password:</label><br>
        <input type="password" name="confirm_password" autocomplete="new-password" required><br><br>

        <button type="submit">Register</button>
    </form>
    </center>
</body>
</html>