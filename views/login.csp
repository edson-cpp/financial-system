<!DOCTYPE html>
<html>
<head>
    <title>Login</title>
</head>
<body>
    <br><br>
    <center>
    <h2>Login</h2>

    <form method="POST" action="/login">
        <label>Login:</label><br>
        <input type="text" name="login" required><br><br>

        <label>Password:</label><br>
        <input type="password" name="pwd" required><br><br>

        <button type="submit">Login</button>
    </form>
    </center>
</body>
</html>
